# Database Configuration
# PostgreSQL connection string - REQUIRED
# Change user, password, host, and database name as needed
DATABASE_URL=postgresql://user:password@localhost:5432/ai_platform

# Security Configuration
# Secret key for JWT signing - REQUIRED
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 characters recommended
SECRET_KEY=your-secure-secret-key-min-32-chars

# JWT Algorithm
ALGORITHM=HS256

# CORS Configuration (comma-separated if multiple)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Upload Configuration
# Maximum upload size in MB (1-500)
MAX_UPLOAD_SIZE_MB=50

# Allowed file extensions (comma-separated, without dots)
ALLOWED_FILE_EXTENSIONS=pdf

# OpenAI API Configuration
# Only needed if using OpenAI embeddings/LLM
OPENAI_API_KEY=sk-your-openai-api-key-here
